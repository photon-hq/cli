{
  "name": "dashboard-cli",
  "version": "0.0.1",
  "description": "Dashboard CLI",
  "type": "module",
  "private": true,
  "bin": {
    "dashboard": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "bun build ./src/index.ts --outfile dist/dashboard.js --target bun --minify",
    "compile": "bun build ./src/index.ts --compile --outfile dist/dashboard",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^14.0.0",
    "commander": "^14.0.3"
  }
}
